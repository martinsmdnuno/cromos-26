{
  "name": "@cromos/shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./stickers": {
      "types": "./dist/stickers.d.ts",
      "default": "./dist/stickers.js"
    },
    "./trade-optimizer": {
      "types": "./dist/trade-optimizer.d.ts",
      "default": "./dist/trade-optimizer.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch --preserveWatchOutput",
    "typecheck": "tsc --noEmit",
    "test": "node --test --import tsx 'src/*.test.ts' || true",
    "lint": "echo 'no lint configured'",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
