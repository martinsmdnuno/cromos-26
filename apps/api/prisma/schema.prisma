// Cromos 26 — database schema
// Run `pnpm --filter @cromos/api prisma:migrate` to create migrations.

generator client {
  provider      = "prisma-client-js"
  // "native" covers local development (macOS/Linux on host).
  // "linux-musl-openssl-3.0.x" is required for Alpine-based Docker images.
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  // Optional: users created via Google OAuth have no password.
  passwordHash String?
  // Google's `sub` claim — stable per-user identifier from the ID token.
  googleId     String?  @unique
  // URL to the user's Google avatar (optional, populated on first OAuth login).
  avatarUrl    String?
  // Admin flag — gates the /admin area + /api/admin/* endpoints. Bootstrap
  // via scripts/make-admin.sh on the server. Default false for every signup.
  isAdmin      Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  stickers      UserSticker[]
  memberships   GroupMembership[]
  createdGroups Group[]           @relation("GroupCreator")
}

/// Lightweight in-house analytics. Every page view + key action lands here.
/// Page views use name = "page.view" with `path` populated.
model Event {
  id        String   @id @default(cuid())
  /// Nullable for anonymous events (none today, but reserved for future).
  userId    String?
  /// Dot-namespaced event id, e.g. "page.view", "pack.submitted", "group.created".
  name      String
  /// Optional route or screen identifier (e.g. "/collection").
  path      String?
  /// Free-form JSON payload for event-specific dimensions. Keep small.
  props     Json?
  createdAt DateTime @default(now())

  @@index([name, createdAt])
  @@index([userId, createdAt])
  @@index([createdAt])
}

model UserSticker {
  userId        String
  stickerNumber Int
  count         Int      @default(0)
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, stickerNumber])
  @@index([userId])
}

model Group {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy   User              @relation("GroupCreator", fields: [createdById], references: [id])
  memberships GroupMembership[]

  @@index([code])
}

model GroupMembership {
  id       String   @id @default(cuid())
  groupId  String
  userId   String
  joinedAt DateTime @default(now())
  /// Stable color index (0..7) inside the group, mapped to MEMBER_COLOR_CYCLE.
  colorIdx Int

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([userId])
  @@index([groupId])
}

model Feedback {
  id        String   @id @default(cuid())
  /// Nullable so anonymous feedback (no auth) can also land here in the future.
  userId    String?
  message   String
  /// Origin URL or route the user was on when they sent the feedback.
  page      String?
  userAgent String?
  /// Whether the user opted in to be contacted back about this feedback.
  contactOk Boolean  @default(false)
  /// True if we successfully forwarded this feedback by email (Resend).
  emailed   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([createdAt])
}
