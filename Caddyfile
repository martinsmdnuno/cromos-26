# Cromos 26 — Caddy v2 config.
#
# Domain: stickers.martinsnuno.com (subdomain of martinsnuno.com).
# Caddy automatically obtains and renews Let's Encrypt certs — no extra setup.

{
	# Email used by Let's Encrypt for cert expiry notices.
	email admin@martinsnuno.com
}

stickers.martinsnuno.com {
	encode gzip zstd

	# Security headers — applied to every response.
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		# Allow microphone on same-origin (voice input on Open-a-pack); block
		# geolocation and camera since we don't use them.
		Permissions-Policy "geolocation=(), microphone=(self), camera=()"
		# Remove Caddy's default Server header.
		-Server
	}

	# Reverse-proxy /api/* to the Fastify container on the internal network.
	handle /api/* {
		reverse_proxy api:3000
	}

	# Everything else: serve the React SPA, falling back to index.html for client-side routes.
	handle {
		root * /srv/web
		try_files {path} /index.html
		file_server

		# Cache static assets aggressively (Vite hashes filenames).
		@assets {
			path /assets/*
		}
		header @assets Cache-Control "public, max-age=31536000, immutable"

		# Everything that isn't a hashed asset (index.html for every SPA route,
		# the manifest, favicon, etc.) must always revalidate — otherwise the
		# browser keeps serving a cached index.html that points at a deleted
		# bundle after a deploy, and users see a stale or broken app.
		@shell {
			not path /assets/*
		}
		header @shell Cache-Control "no-cache, must-revalidate"
	}

	# Optional: enable an access log if you want to inspect traffic.
	# log {
	# 	output file /var/log/caddy/access.log
	# 	format json
	# }
}

# === Sites tertios proxied through this Caddy ===
# These hosts share the server but live in other docker-compose projects.
# We reach their containers via the cromos-26 network gateway (host bridge).

grapedeal.pt, www.grapedeal.pt {
    reverse_proxy 172.20.0.1:3000
}

grapedeal.duckdns.org {
    redir https://grapedeal.pt{uri} permanent
}

casa.martinsnuno.com {
    reverse_proxy 172.20.0.1:3001
}

limpezas.duckdns.org {
    reverse_proxy 172.20.0.1:3001
}
