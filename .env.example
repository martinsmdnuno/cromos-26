# =====================================================================
# Cromos 26 — environment variables
# Copy to .env (local dev) or .env.production (server) and fill in.
# =====================================================================

# ----- App identity -----
NODE_ENV=development
APP_URL=http://localhost:5173
COOKIE_DOMAIN=localhost

# ----- API -----
API_PORT=3000
# Generate with: openssl rand -base64 48
JWT_SECRET=change-me-to-a-random-48-byte-base64-string
JWT_EXPIRES_IN=30d

# ----- Database -----
# Local dev (running postgres in docker-compose.yml):
DATABASE_URL=postgresql://cromos:cromos@db:5432/cromos?schema=public
POSTGRES_USER=cromos
POSTGRES_PASSWORD=cromos
POSTGRES_DB=cromos

# ----- Google OAuth (optional) -----
# Get these from Google Cloud Console → APIs & Services → Credentials.
# See README.md "Google OAuth setup" for the full walkthrough.
# Leave both blank to disable Google sign-in (the button still renders but will 404).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Public URL of the API itself, used to build the OAuth callback. Leave blank to default
# to APP_URL (correct when frontend & API share the same origin behind Caddy).
API_PUBLIC_URL=

# ----- Feedback email forwarding (optional) -----
# If both are set, /api/feedback forwards each submission via Resend (https://resend.com).
# Without a verified Resend domain the From-address must stay as onboarding@resend.dev
# and the To-address must be the email the Resend account was created with.
RESEND_API_KEY=
FEEDBACK_NOTIFY_EMAIL=
# From-line. Leave default unless you've verified a domain in Resend.
FEEDBACK_FROM_EMAIL=Cromos 26 <onboarding@resend.dev>

# ----- Frontend (Vite, prefixed with VITE_) -----
# In production this is empty (same-origin via Caddy reverse proxy).
# In dev it points at the API container/host.
VITE_API_BASE_URL=http://localhost:3000
